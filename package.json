{
  "name": "duplicate-files-fixer",
  "version": "0.1.0",
  "description": "Duplicate Files Fixer - Desktop Prototype",
  "main": "src/main/main.js",
  "scripts": {
    "dev:renderer": "vite",
    "dev:electron": "NODE_ENV=development electron .",
    "dev": "concurrently \"npm run dev:renderer\" \"wait-on http://localhost:5173 && npm run dev:electron\"",
    "build": "vite build && electron-builder",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.dff.prototype",
    "productName": "Duplicate Files Fixer",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "public/icon.png"
    },
    "files": [
      "dist/**/*",
      "src/main/**/*",
      "package.json"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^4.0.0",
    "@vitest/ui": "^4.1.9",
    "concurrently": "^8.2.2",
    "electron": "^30.0.0",
    "electron-builder": "^24.0.0",
    "jsdom": "^29.1.1",
    "vite": "^5.0.0",
    "vitest": "^4.1.9",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  }
}
